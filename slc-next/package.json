{
  "name": "slc-next",
  "version": "0.1.0",
  "private": true,
  "description": "Single-page landing scanner built from yan-template-next-2026.",
  "engines": {
    "node": ">=24 <26",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm run design:tokens && tsx watch --clear-screen=false server.ts",
    "build": "pnpm run design:tokens && next build",
    "start": "pnpm run design:tokens && NODE_ENV=production tsx server.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/api",
    "test:e2e": "bddgen test && playwright test",
    "test:storybook": "storybook build --quiet",
    "test": "pnpm run test:unit && pnpm run test:api && pnpm run test:e2e && pnpm run test:storybook",
    "storybook": "pnpm run design:tokens && storybook dev -p 6006",
    "build-storybook": "pnpm run design:tokens && storybook build",
    "generate:component": "plop component",
    "generate:server-module": "plop server-module",
    "generate:feature": "plop feature",
    "design:tokens": "tsx scripts/generate-design-tokens.ts"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "playwright-bdd": "^8.5.0",
    "plop": "^4.0.5",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3",
    "wait-on": "^9.0.4"
  }
}
