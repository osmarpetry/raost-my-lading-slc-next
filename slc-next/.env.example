# Core
NODE_ENV=development
PORT=3000

# Postgres
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/slc

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI
# Without OPENAI_API_KEY, final synthesis fails explicitly.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-nano
OPENAI_TIMEOUT_MS=25000

# Lighthouse
# Without Chrome/Chromium, local Lighthouse fails explicitly.
LIGHTHOUSE_PROVIDER=local
LIGHTHOUSE_TIMEOUT_MS=60000
CHROME_PATH=

# Optional PageSpeed alternate
# PageSpeed is explicit alternate provider, never silent fallback.
PAGESPEED_API_KEY=
PAGESPEED_STRATEGY=mobile
PAGESPEED_TIMEOUT_MS=25000

# Ollama fallback (used when OPENAI_API_KEY is missing)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:0.5b
OLLAMA_TIMEOUT_MS=30000

# Strictness
ALLOW_PROVIDER_FALLBACK=false
